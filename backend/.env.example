HOST=0.0.0.0
PORT=8787

# Sessions / OTP
SESSION_TTL_HOURS=72
EMAIL_CODE_TTL_MIN=15
EXPOSE_DEV_EMAIL_CODE=false

# Email provider (recommended for production)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
EMAIL_FROM="Padely <onboarding@resend.dev>"
VERIFY_BASE_URL="https://api.padely.app/api/v1/auth/verify"

# SMTP fallback (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_user
# SMTP_PASS=your_password

# OAuth verification
GOOGLE_CLIENT_ID=
APPLE_BUNDLE_ID=com.tanoudb.padely
APPLE_SERVICE_ID=
ALLOW_INSECURE_OAUTH_DEV=false

# Admin emails
ADMIN_EMAILS=admin@padely.app
